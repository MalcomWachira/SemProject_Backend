generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VermicultureTelemetry {
  id           String   @id @default(uuid())
  bedId        String
  moisture     Float
  ph           Float
  ambientTemp  Float
  ambientHum   Float
  status       String
  recordedAt   DateTime @default(now())

  @@index([bedId])
  @@index([recordedAt])
}